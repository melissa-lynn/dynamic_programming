  <listing>
    <caption>Using recursion to compute the Fibonacci Sequence</caption>
    <program interactive='activecode' language="python" label="program-activecode-fibonacci-recursion" include-source="yes">
        <code>
        def fibonacci(n):
          if n == 1 or n == 2:
            return 1
          return fibonacci(n-1) + fibonacci(n-2)

        print(fibonacci(10))
        </code>
    </program>
</listing>


